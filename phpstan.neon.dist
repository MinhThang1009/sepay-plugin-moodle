# PHPStan config cho enrol_sepay (Moodle-aware tối giản).
# Chạy: phpstan analyse -c phpstan.neon.dist (từ thư mục plugin, trong cây Moodle đã cài).
# Paths tương đối so với file này: . = plugin, ../../lib + ../../enrol = Moodle core.
parameters:
    level: 4
    paths:
        - .
    excludePaths:
        analyse:
            - phpstan-bootstrap.php
    scanDirectories:
        - ../../lib
        - ../../enrol
    bootstrapFiles:
        - phpstan-bootstrap.php
    reportUnmatchedIgnoredErrors: false
    # Bỏ qua các identifier là false-positive do PHPStan không hiểu hết magic của Moodle
    # (class autoload, magic property, global $CFG/$DB...). Phần còn lại là lỗi logic thật.
    ignoreErrors:
        - identifier: variable.undefined
        - identifier: class.notFound
        - identifier: property.private
        - identifier: property.notFound
        - identifier: method.notFound
        - identifier: constant.notFound
        - identifier: assign.propertyType
