{{!
    @template enrol_sepay/enrol

    Form QR thanh toán SePay hiển thị trên trang ghi danh khóa học.

    Context variables required for this template:
    * qr_account - Số tài khoản nhận tiền
    * qr_bank - Mã ngân hàng
    * cost - Số tiền cần chuyển
    * qr_content - Nội dung chuyển khoản (dùng để đối soát)
    * qr_template - Tên template QR của SePay
    * localisedcost - Số tiền đã định dạng để hiển thị

    Example context (json):
    {
        "qr_account": "0123456789",
        "qr_bank": "MB",
        "cost": "100000",
        "qr_content": "SEPAY123",
        "qr_template": "compact",
        "localisedcost": "100.000 VND"
    }
}}
<div class="enrol-sepay-wrapper">
  <div class="bank-card">
    <div class="card-header">Quét mã QR hoặc chuyển khoản để tự động ghi danh vào khoá học này!</div>
    <div class="card-body">
      <div class="qr-section">
        <div class="qr-image-wrapper">
          <img decoding="async" id="img_qr_code" class="img-fluid rounded"
            src="https://qr.sepay.vn/img?acc={{qr_account}}&bank={{qr_bank}}&amount={{cost}}&des={{qr_content}}&template={{qr_template}}"
            alt="QR Code">
        </div>
        <a href="#" class="download-qr-btn" data-action="download-qr">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
            <path
              d="M288 32c0-17.7-14.3-32-32-32s-32 14.3-32 32V274.7l-73.4-73.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l128 128c12.5 12.5 32.8 12.5 45.3 0l128-128c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L288 274.7V32zM64 352c-35.3 0-64 28.7-64 64v32c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V416c0-35.3-28.7-64-64-64H346.5l-45.3 45.3c-25 25-65.5 25-90.5 0L165.5 352H64zm368 56a24 24 0 1 1 0 48 24 24 0 1 1 0-48z" />
          </svg>
          Tải ảnh QR
        </a>
      </div>
      <div class="info-section">
        <h4>Thông Tin Chuyển Khoản</h4>
        <div class="info-row">
          <div class="info-content">
            <div class="info-label">Ngân hàng</div>
            <div class="info-value">
              {{qr_bank}}
            </div>
          </div>
        </div>
        <div class="info-row">
          <div class="info-content">
            <div class="info-label">Số tài khoản</div>
            <div class="info-value">
              {{qr_account}}
            </div>
          </div>
          <button class="copy-btn" data-action="copy" data-clipboard-text="{{qr_account}}" title="Copy">
            <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path
                d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" />
            </svg>
            <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
            </svg>
          </button>
        </div>
        <div class="info-row">
          <div class="info-content">
            <div class="info-label">Nội dung CK</div>
            <div class="info-value">
              {{qr_content}}
            </div>
          </div>
          <button class="copy-btn" data-action="copy" data-clipboard-text="{{qr_content}}" title="Copy">
            <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path
                d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" />
            </svg>
            <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" />
            </svg>
          </button>
        </div>
        <div class="info-row">
          <div class="info-content">
            <div class="info-label">Số tiền CK</div>
            <div class="info-value">
              {{localisedcost}}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Trạng thái vòng lặp kiểm tra thanh toán (gắn bằng JS). -->
  <div id="payment-status-indicator">
    <div class="spinner-border"></div>
    <span>Đang kiểm tra trạng thái thanh toán<span id="checking-dots"></span></span>
  </div>
</div>
