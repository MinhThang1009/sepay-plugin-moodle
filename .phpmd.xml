<?xml version="1.0"?>
<ruleset name="enrol_sepay"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">
    <description>
        Ruleset PHPMD cho enrol_sepay = bộ mặc định của moodle-plugin-ci
        (codesize + unusedcode + naming trừ ShortVariable + design) nhưng loại
        đúng các rule mà MỌI vi phạm còn lại trong plugin đều do chữ ký/cấu trúc
        API Moodle ép, không sửa được. Các rule về độ phức tạp, độ dài method/class
        và dead code VẪN BẬT (code đã được refactor/dọn để pass), nên vi phạm mới
        thuộc nhóm đó vẫn bị bắt.
    </description>

    <rule ref="rulesets/codesize.xml">
        <!-- enrol_sepay_plugin (override API enrol_plugin) và transactions_table
             (col_* bắt buộc của table_sql) có nhiều public method do framework ép,
             không gộp/bớt được. -->
        <exclude name="TooManyPublicMethods"/>
        <exclude name="ExcessivePublicCount"/>
        <!-- Độ phức tạp tổng của class dồn từ các method API bắt buộc của enrol_plugin. -->
        <exclude name="ExcessiveClassComplexity"/>
    </rule>

    <rule ref="rulesets/unusedcode.xml">
        <!-- Param không dùng còn lại đều là override chữ ký Moodle (enrol_plugin:
             allow_unenrol/allow_manage/restore_user_enrolment/edit_instance_validation;
             bulk operation: process()) - bắt buộc giữ đúng signature. -->
        <exclude name="UnusedFormalParameter"/>
    </rule>

    <rule ref="rulesets/naming.xml">
        <!-- Moodle dùng tên biến ngắn: $DB, $rs, $a... -->
        <exclude name="ShortVariable"/>
        <!-- Tên class bulk-operation theo convention enrol/manual
             (enrol_sepay_deleteselectedusers_operation) dài >40 ký tự. -->
        <exclude name="LongClassName"/>
    </rule>

    <rule ref="rulesets/design.xml"/>
</ruleset>
