<?xml version="1.0"?>
<ruleset name="enrol_sepay">
    <description>Chuẩn Moodle cho enrol_sepay, có điều chỉnh cho codebase tiếng Việt.</description>

    <rule ref="moodle">
        <!--
            moodle-cs dùng regex ASCII (A-Z) để kiểm tra chữ hoa đầu inline comment, nên
            KHÔNG chấp nhận chữ hoa tiếng Việt (Đ, Ư, Ơ, Â, Ê, Ô...). Comment của plugin
            viết tiếng Việt và đã viết hoa đúng, nên loại sniff này để khỏi false-positive.
        -->
        <exclude name="moodle.Commenting.InlineComment.NotCapital"/>
    </rule>
</ruleset>
